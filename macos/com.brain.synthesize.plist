<?xml version="1.0" encoding="UTF-8"?>
<!-- Template: replace YOUR_USERNAME with your macOS username (plists require absolute paths). -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brain.synthesize</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOUR_USERNAME/.claude/brain/synthesize.sh</string>
    </array>
    <!-- Nightly at 03:00. Runs on next wake if the Mac is asleep. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>3</integer>
        <key>Minute</key><integer>0</integer>
    </dict>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key><string>/Users/YOUR_USERNAME</string>
        <key>PATH</key><string>/Users/YOUR_USERNAME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>StandardOutPath</key><string>/Users/YOUR_USERNAME/.claude/brain/launchd-out.log</string>
    <key>StandardErrorPath</key><string>/Users/YOUR_USERNAME/.claude/brain/launchd-err.log</string>
</dict>
</plist>
